---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("daily");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title={`${post.data.title} | 健康经济学知识站`}>
  <a href="/daily" class="back-link">← 返回存档</a>

  <div class="article-meta">
    <time datetime={post.data.date.toISOString()}>
      🗓️ {formatDate(post.data.date)}
    </time>
    <span>·</span>
    <span>🦐 每日小知识</span>
  </div>

  <article class="article">
    <Content />
  </article>

  <div style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
    <a href="/daily" class="back-link">← 查看更多小知识</a>
  </div>
</Base>
