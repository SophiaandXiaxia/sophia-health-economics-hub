---
import Base from "../layouts/Base.astro";
---

<Base title="📡 NICE 动态追踪 | 健康经济学知识站">
  <div class="section-title">📡 NICE 动态追踪</div>

  <div class="coming-soon" style="margin-top: 2rem;">
    <span class="emoji">🔍</span>
    <h3
      style="font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.75rem;"
    >
      即将上线
    </h3>
    <p
      style="font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.8; max-width: 420px; margin: 0 auto;"
    >
      自动追踪 NICE 最新指南更新、EQ-5D-5L Value Set 发布、技术评估审批动态等内容，第一时间为你整理要点。
    </p>
    <div style="margin-top: 1.5rem;">
      <span class="tag" style="font-size: 0.8rem; padding: 0.35rem 0.9rem;"
        >🔔 预计上线：Phase 2</span
      >
    </div>
  </div>
</Base>
