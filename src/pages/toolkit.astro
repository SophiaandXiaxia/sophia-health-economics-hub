---
import Base from '../../layouts/Base.astro';
---

<Base title="🔧 实用工具箱 | 健康经济学知识站">
  <p style="color: var(--color-text-muted); font-size: 0.88rem; margin-bottom: 2rem; margin-top: -0.5rem;">
    UK 健康经济学核心资源 · 收藏这一篇就够了
  </p>

  <!-- 数据来源 -->
  <div class="section-title" style="font-size: 1rem; margin-top: 2rem;">📊 核心数据来源</div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">🏆 EuroQol & EQ-5D</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">获取 UK & 国际健康效用值 (Value Sets)</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://euroqol.org/information-and-support/euroqol-instruments/eq-5d-5l/" style="color: var(--color-primary);">euroqol.org</a><br>
      <strong>用途：</strong> 获取不同健康状态的效用值，用于计算 QALY<br>
      <strong>推荐：</strong> UK 常用 EQ-5D-5L value set
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">效用值</span>
      <span class="tag">QALY 计算</span>
      <span class="tag">EQ-5D</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">💷 NHS Reference Costs</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">英国医疗服务成本官方数据</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://www.england.nhs.uk/national-cost-collection/" style="color: var(--color-primary);">england.nhs.uk/national-cost-collection</a><br>
      <strong>用途：</strong> 医院服务、手术、检查等成本<br>
      <strong>更新：</strong> 每年发布
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">成本数据</span>
      <span class="tag">NHS</span>
      <span class="tag">ICER</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📈 PSSRU Unit Costs</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">社会服务与医疗人员成本年鉴</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://www.pssru.ac.uk/unit-costs/" style="color: var(--color-primary);">pssru.ac.uk/unit-costs</a><br>
      <strong>用途：</strong> 护士、医生、社会工作者等时薪<br>
      <strong>亮点：</strong> 含"社会时间价值"估算
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">人力成本</span>
      <span class="tag">PSSRU</span>
      <span class="tag">年鉴</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📉 BNF</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">英国国家处方集</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://bnf.nice.org.uk/" style="color: var(--color-primary);">bnf.nice.org.uk</a><br>
      <strong>用途：</strong> 药品价格、用药指导<br>
      <strong>亮点：</strong> 处方药成本计算必备
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">药品成本</span>
      <span class="tag">BNF</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📋 NICE Guidance</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">英国 NICE 指南与评估</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://www.nice.org.uk/guidance" style="color: var(--color-primary);">nice.org.uk/guidance</a><br>
      <strong>用途：</strong> 查找已评估的卫生技术、临床指南<br>
      <strong>亮点：</strong> 含成本效益评估、ICER 阈值参考
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">HTA</span>
      <span class="tag">NICE</span>
      <span class="tag">阈值</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">🔬 PubMed / MEDLINE</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">生物医学文献数据库</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://pubmed.ncbi.nlm.nih.gov/" style="color: var(--color-primary);">pubmed.ncbi.nlm.nih.gov</a><br>
      <strong>用途：</strong> 文献检索、临床试验注册<br>
      <strong>技巧：</strong> 使用 MeSH 词检索更精准
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">文献检索</span>
      <span class="tag">MeSH</span>
      <span class="tag">RCT</span>
    </div>
  </div>

  <!-- 术语表 -->
  <div class="section-title" style="font-size: 1rem; margin-top: 2.5rem;">📖 核心术语速查</div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">🔑 关键词汇</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">快速理解健康经济学核心概念</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>QALY：</strong> Quality-Adjusted Life Year，质量调整生命年<br>
      <strong>ICER：</strong> Incremental Cost-Effectiveness Ratio，增量成本效果比<br>
      <strong>NMB：</strong> Net Monetary Benefit，净货币收益<br>
      <strong>WTP：</strong> Willingness to Pay，支付意愿<br>
      <strong>HTA：</strong> Health Technology Assessment，卫生技术评估
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">术语</span>
      <span class="tag">概念</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📊 统计与建模基础</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">常用分析框架与模型类型</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>Markov 模型：</strong> 疾病状态转移概率模型<br>
      <strong>决策树：</strong> 简单路径概率分析<br>
      <strong>分区生存模型：</strong> partitioned survival model，常用于肿瘤<br>
      <strong>蒙特卡洛模拟：</strong> Monte Carlo，微观模拟方法<br>
      <strong>分区敏感性分析：</strong> Probabilistic Sensitivity Analysis (PSA)
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">建模</span>
      <span class="tag">Markov</span>
      <span class="tag">敏感性分析</span>
    </div>
  </div>

  <!-- 数据库 -->
  <div class="section-title" style="font-size: 1rem; margin-top: 2.5rem;">🗄️ 文献与数据库</div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📚 NHS EED & HEED</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">健康经济评估数据库</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>NHS EED：</strong> Economic Evaluation Database（系统综述卫生干预效果）<br>
      <strong>HEED：</strong> Health Economic Evaluations Database<br>
      <strong>用途：</strong> 文献检索、meta 分析、基准参考
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">文献</span>
      <span class="tag">数据库</span>
      <span class="tag">检索</span>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">📖 Cochrane Library</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">循证医学金标准</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>网址：</strong> <a href="https://www.cochranelibrary.com/" style="color: var(--color-primary);">cochranelibrary.com</a><br>
      <strong>用途：</strong> 获取临床证据、系统综述<br>
      <strong>结合：</strong> 与 HTA 配合使用
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">临床证据</span>
      <span class="tag">系统综述</span>
    </div>
  </div>

  <!-- 软件工具 -->
  <div class="section-title" style="font-size: 1rem; margin-top: 2.5rem;">💻 分析工具</div>

  <div class="card">
    <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem;">🧮 常用软件</h3>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">健康经济学建模与分析工具</p>
    <div style="background: var(--color-tag-bg); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem;">
      <strong>R / RStudio：</strong> 免费、强大、统计与建模首选<br>
      <strong>TreeAge：</strong> 决策树 & Markov 模型专用<br>
      <strong>Excel：</strong> 基础分析、快速原型<br>
      <strong>Excel with R：</strong> 报告自动化
    </div>
    <div style="margin-top: 0.75rem;">
      <span class="tag">R</span>
      <span class="tag">TreeAge</span>
      <span class="tag">Excel</span>
      <span class="tag">Python</span>
    </div>
  </div>

  <!-- 底部提示 -->
  <div style="margin-top: 3rem; padding: 1.5rem; background: linear-gradient(135deg, #f0fdfa, #ccfbf1); border-radius: 12px; text-align: center;">
    <p style="font-size: 0.9rem; color: var(--color-primary-dark);">
      🦞 <strong>收藏这个页面</strong>，做健康经济学项目时随时回来查阅！<br>
      <small style="opacity: 0.8;">大量学习 · 大量研究 · 大量重复 · 不断实践</small>
    </p>
  </div>
</Base>
