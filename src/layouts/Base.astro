---
const { title } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Sophia Health Economics Hub</title>
</head>
<body>
    <nav>
        <ul>
            <li><a href={`${BASE}/`}>Home</a></li>
            <li><a href={`${BASE}/news`}>News</a></li>
            <li><a href={`${BASE}/resources`}>Resources</a></li>
            <li><a href={`${BASE}/toolkit`}>Toolkit</a></li>
            <li><a href={`${BASE}/archive`}>📁 Project Archive</a></li>
        </ul>
    </nav>
    <main>
        <slot />
    </main>
    <footer>
        <p>&copy; 2026 Sophia Health Economics Hub</p>
    </footer>
</body>
</html>

<style>
    nav ul {
        display: flex;
        gap: 1rem;
        list-style: none;
        padding: 1rem;
        background: #f5f5f5;
    }
    nav a {
        text-decoration: none;
        color: #333;
    }
    main {
        padding: 2rem;
    }
</style>

