---
interface Props {
  title?: string;
  description?: string;
}
const { title = "🦞 健康经济学知识站", description = "每日健康经济学小知识，助你成为资深健康经济学专家" } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Health Economics Hub</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@600;700&display=swap" rel="stylesheet">
</head>
<body>
  <header class="site-header">
    <h1>🦞</h1>
    <p>
      {title}<br>
      <small>每天一个小知识，陪你成长为资深健康经济学专家 🦞</small>
    </p>
    <div class="lobster-bg">🦞</div>
  </header>
  
  <nav class="site-nav">
    <ul>
      <li><a href={`${BASE}/`}>🏠 首页</a></li>
      <li><a href={`${BASE}/daily`}>📅 每日小知识</a></li>
      <li><a href={`${BASE}/toolkit`}>🔧 实用工具箱</a></li>
      <li><a href={`${BASE}/news`}>📰 NICE 动态</a></li>
    </ul>
  </nav>
  
  <main class="main-content">
    <slot />
  </main>
  
  <footer class="site-footer">
    <p>Powered by WorkBuddy · University of Surrey Health Economics</p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --color-primary: #0f766e;
    --color-primary-dark: #115e59;
    --color-primary-light: #14b8a6;
    --color-accent: #059669;
    --color-bg: #f0fdfa;
    --color-bg-alt: #ccfbf1;
    --color-card: #ffffff;
    --color-text: #134e4a;
    --color-text-muted: #5eead4;
    --color-border: #99f6e4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    background: linear-gradient(135deg, #ccfbf1 0%, #f0fdfa 40%, #d1fae5 100%);
    min-height: 100vh;
    color: var(--color-text);
    line-height: 1.7;
  }
  .site-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    text-align: center;
    padding: 2.5rem 1rem 3rem;
    position: relative;
    overflow: hidden;
  }
  .site-header h1 { font-size: 3.5rem; margin-bottom: 0.5rem; }
  .site-header p { font-size: 1.1rem; opacity: 0.95; line-height: 1.8; }
  .site-header small { opacity: 0.8; font-size: 0.95rem; }
  .lobster-bg {
    position: absolute;
    font-size: 10rem;
    opacity: 0.1;
    right: -2rem;
    bottom: -2rem;
    transform: rotate(-15deg);
  }
  .site-nav {
    background: white;
    padding: 0;
    box-shadow: 0 2px 8px rgba(15, 118, 110, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-nav ul {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    list-style: none;
    border-bottom: 3px solid var(--color-border);
  }
  .site-nav a {
    display: block;
    padding: 1rem 1.5rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
    border-bottom: 3px solid transparent;
    margin-bottom: -3px;
  }
  .site-nav a:hover {
    color: var(--color-primary);
    background: var(--color-bg-alt);
  }
  .main-content {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .site-footer {
    background: var(--color-primary);
    color: white;
    text-align: center;
    padding: 2rem 1rem;
    margin-top: 3rem;
  }
  h1 { color: var(--color-primary); margin-bottom: 1rem; }
  h2 { color: var(--color-primary-dark); margin: 1.5rem 0 0.75rem; font-size: 1.5rem; }
  h3 { color: var(--color-text); }
  .card {
    background: var(--color-card);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 1.25rem 0;
    box-shadow: 0 4px 16px rgba(15, 118, 110, 0.08);
    border: 1px solid var(--color-border);
  }
  .tag {
    display: inline-block;
    background: var(--color-bg-alt);
    color: var(--color-primary-dark);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    margin: 0.2rem;
  }
  @media (max-width: 640px) {
    .site-header h1 { font-size: 2.5rem; }
    .site-nav ul { flex-wrap: wrap; }
    .site-nav a { padding: 0.75rem 1rem; font-size: 0.9rem; }
  }
</style>
