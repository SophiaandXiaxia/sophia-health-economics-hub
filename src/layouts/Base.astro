---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "🦞 健康经济学知识站",
  description = "每日健康经济学小知识，助你成为资深健康经济学专家",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --color-primary: #0f766e;
        --color-primary-light: #14b8a6;
        --color-primary-dark: #0d4f49;
        --color-accent: #f59e0b;
        --color-bg: #f8fafb;
        --color-surface: #ffffff;
        --color-border: #e2e8f0;
        --color-text: #1e293b;
        --color-text-muted: #64748b;
        --color-tag-bg: #ccfbf1;
        --color-tag-text: #0f766e;
        --radius: 12px;
        --shadow: 0 2px 8px rgba(15, 118, 110, 0.08);
        --shadow-hover: 0 8px 24px rgba(15, 118, 110, 0.15);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Noto Sans SC", "PingFang SC", "Microsoft YaHei",
          sans-serif;
        background-color: var(--color-bg);
        background-image:
          radial-gradient(ellipse at 20% 20%, rgba(20, 184, 166, 0.08) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 80%, rgba(245, 158, 11, 0.06) 0%, transparent 50%),
          radial-gradient(ellipse at 60% 10%, rgba(15, 118, 110, 0.05) 0%, transparent 40%);
        color: var(--color-text);
        line-height: 1.8;
        min-height: 100vh;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        33% { transform: translateY(-8px) rotate(2deg); }
        66% { transform: translateY(4px) rotate(-1deg); }
      }

      @keyframes float-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
      }

      @keyframes drift {
        0% { transform: translateX(0) translateY(0); opacity: 0.5; }
        100% { transform: translateX(30px) translateY(-40px); opacity: 0; }
      }

      .container::before {
        content: "📊";
        font-size: 2rem;
        position: fixed;
        top: 35%;
        left: 5%;
        opacity: 0.08;
        animation: float-slow 10s ease-in-out infinite;
        pointer-events: none;
      }

      .container::after {
        content: "💊";
        font-size: 1.8rem;
        position: fixed;
        bottom: 20%;
        right: 6%;
        opacity: 0.08;
        animation: float-slow 12s ease-in-out infinite reverse;
        pointer-events: none;
      }

      /* ── Header ── */
      .site-header {
        background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 60%, var(--color-primary-light) 100%);
        color: white;
        padding: 3rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .site-header::before {
        content: "🦞";
        font-size: 7rem;
        position: absolute;
        top: 0.5rem;
        right: 2.5rem;
        opacity: 0.15;
        animation: float 6s ease-in-out infinite;
      }

      .site-header h1 {
        font-family: "Noto Serif SC", serif;
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
      }

      .site-header p {
        font-size: 0.95rem;
        opacity: 0.85;
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.6;
      }

      /* ── Nav ── */
      .site-nav {
        background: white;
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: var(--shadow);
      }

      .site-nav ul {
        list-style: none;
        display: flex;
        justify-content: center;
        gap: 0;
        max-width: 800px;
        margin: 0 auto;
      }

      .site-nav li a {
        display: block;
        padding: 1rem 1.5rem;
        text-decoration: none;
        color: var(--color-text-muted);
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s;
        border-bottom: 3px solid transparent;
        letter-spacing: 0.03em;
      }

      .site-nav li a:hover,
      .site-nav li a.active {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
        background: var(--color-bg);
      }

      /* ── Main ── */
      .container {
        max-width: 860px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      /* ── Footer ── */
      .site-footer {
        text-align: center;
        padding: 2rem;
        border-top: 1px solid var(--color-border);
        color: var(--color-text-muted);
        font-size: 0.85rem;
        margin-top: 2rem;
      }

      .site-footer a {
        color: var(--color-primary);
        text-decoration: none;
      }

      /* ── Cards ── */
      .card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 1.75rem;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
        transition: all 0.25s;
        cursor: pointer;
      }

      .card:hover {
        box-shadow: var(--shadow-hover);
        transform: translateY(-4px) scale(1.01);
        border-color: var(--color-primary-light);
      }

      .card a {
        text-decoration: none;
        color: inherit;
        display: block;
      }

      /* ── Tags ── */
      .tag {
        display: inline-block;
        background: var(--color-tag-bg);
        color: var(--color-tag-text);
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.2rem 0.65rem;
        border-radius: 20px;
        letter-spacing: 0.03em;
        margin-right: 0.35rem;
        margin-bottom: 0.35rem;
      }

      /* ── Article ── */
      .article-meta {
        font-size: 0.82rem;
        color: var(--color-text-muted);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .article-meta time {
        font-weight: 500;
      }

      .article h1,
      .article h2,
      .article h3 {
        font-family: "Noto Serif SC", serif;
        color: var(--color-text);
        margin: 1.5em 0 0.6em;
        line-height: 1.4;
      }

      .article h1 {
        font-size: 1.75rem;
        border-bottom: 2px solid var(--color-primary-light);
        padding-bottom: 0.5rem;
        margin-top: 0;
      }

      .article h2 {
        font-size: 1.3rem;
        color: var(--color-primary);
      }

      .article p {
        margin-bottom: 1rem;
        color: var(--color-text);
        line-height: 2;
      }

      .article blockquote {
        background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
        border-left: 4px solid var(--color-primary);
        padding: 1rem 1.25rem;
        border-radius: 0 var(--radius) var(--radius) 0;
        margin: 1.25rem 0;
        font-weight: 500;
        color: var(--color-primary-dark);
      }

      .article strong {
        color: var(--color-primary-dark);
        font-weight: 600;
      }

      .article hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
      }

      /* ── Hero card ── */
      .hero-card {
        background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
        color: white;
        border-radius: var(--radius);
        padding: 2.5rem;
        margin-bottom: 2.5rem;
        position: relative;
        overflow: hidden;
      }

      .hero-card::after {
        content: "🦞";
        font-size: 6rem;
        position: absolute;
        right: 1.5rem;
        bottom: -0.5rem;
        opacity: 0.12;
        animation: float-slow 8s ease-in-out infinite;
      }

      .hero-card h2 {
        font-family: "Noto Serif SC", serif;
        font-size: 1.6rem;
        margin-bottom: 0.75rem;
        color: white;
      }

      .hero-card p {
        opacity: 0.9;
        font-size: 0.95rem;
        line-height: 1.7;
        max-width: 480px;
      }

      /* ── Section title ── */
      .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--color-primary-light);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .section-title::before {
        content: "";
        width: 4px;
        height: 1.1rem;
        background: var(--color-primary);
        border-radius: 2px;
      }

      /* ── Back link ── */
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-primary);
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        transition: all 0.2s;
      }

      .back-link:hover {
        background: var(--color-tag-bg);
      }

      /* ── Coming soon ── */
      .coming-soon {
        text-align: center;
        padding: 3rem;
        background: var(--color-surface);
        border: 2px dashed var(--color-border);
        border-radius: var(--radius);
        color: var(--color-text-muted);
      }

      .coming-soon .emoji {
        font-size: 3rem;
        margin-bottom: 1rem;
        display: block;
      }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .site-header {
          padding: 2rem 1.25rem;
        }
        .site-header h1 {
          font-size: 1.5rem;
        }
        .site-nav ul {
          overflow-x: auto;
          justify-content: flex-start;
          padding: 0 1rem;
        }
        .container {
          padding: 1.5rem 1rem 3rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1>{title}</h1>
      <p>
        每天一个小知识，陪你成长为资深健康经济学专家 🦞<br />
        <small
          >Powered by WorkBuddy · University of Surrey Health Economics</small
        >
      </p>
    </header>

    <!-- Wave Divider -->
    <div style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 60%, var(--color-primary-light) 100%); height: 8px; margin-top: -1px;"></div>
    <svg style="display: block; margin-top: -2px;" viewBox="0 0 1440 40" xmlns="http://www.w3.org/2000/svg" width="100%">
      <path d="M0,20 C240,40 480,0 720,20 C960,40 1200,0 1440,20 L1440,40 L0,40 Z" fill="#f8fafb"/>
    </svg>

    <nav class="site-nav">
      <ul>
        <li><a href="/" class="active">🏠 首页</a></li>
        <li><a href="/daily">📅 每日小知识</a></li>
        <li><a href="/news">📰 NICE 动态</a></li>
        <li><a href="/resources">📚 学习资源</a></li>
      </ul>
    </nav>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        🦞 健康经济学知识站 · 由
        <a href="#">WorkBuddy AI</a> 驱动 · 萨里大学健康经济学中心
      </p>
      <p style="margin-top: 0.5rem; opacity: 0.6; font-size: 0.78rem">
        Built for Sophia · 2026
      </p>
    </footer>
  </body>
</html>
